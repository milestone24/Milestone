{
  "include": ["src/**/*", "vitest.config.ts", "vitest.globalSetup.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "target": "es2015",
    "lib": ["dom", "es2023"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": ["node", "vite/client", "vitest/globals"],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../../packages/js-common/src/*"],
      "@milestone/js-common": ["../../packages/js-common/src/index.ts"],
      "@milestone/js-common/*": ["../../packages/js-common/src/*"]
    }
  }
}
