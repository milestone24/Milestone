{
  "include": ["tools/**/*", "dev/**/*.ts", "vitest.config.ts", "vitest.globalSetup.ts"],
  "exclude": ["node_modules", "build", "dist"],
  "compilerOptions": {
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "target": "es2015",
    "lib": ["dom", "es2023"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client", "vitest/globals"],
    "paths": {
      "@/*": ["./apps/api-primary-node/src/*"],
      "@shared/*": ["./packages/js-common/src/*"],
      "@milestone/js-common": ["./packages/js-common/src/index.ts"],
      "@milestone/js-common/*": ["./packages/js-common/src/*"]
    }
  }
}
