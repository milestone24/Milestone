  "scripts": {
    "dev": "tsx --inspect server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "test:ocr": "tsx dev/test-ocr.ts",
    "email-inbound:tap-watch": "tsx tools/aws/email-inbound-queue-util.ts exec",
    "email-inbound:tap-watch:no-delete": "tsx tools/aws/email-inbound-queue-util.ts exec --no-delete",
    "email-inbound:queue-stats": "tsx tools/aws/email-inbound-queue-util.ts exec --stats-only",
    "email-inbound:sqs-list": "tsx tools/aws/email-inbound-queue-util.ts show --sqs",
    "email-inbound:sns-list": "tsx tools/aws/email-inbound-queue-util.ts show --sns",
    "email-inbound:queues-depths": "tsx tools/aws/email-inbound-queue-util.ts show --depths",
    "email-inbound:events-list": "tsx tools/aws/email-inbound-queue-util.ts events list",
    "email-inbound:events-clear": "tsx tools/aws/email-inbound-queue-util.ts events clear",
    "test": "vitest",
    "test:run": "vitest run",
    "db:push": "drizzle-kit push",
    "cdk": "cd infrastructure && cdk",
    "cdk:synth": "cd infrastructure && cdk synth",
    "cdk:deploy": "cd infrastructure && cdk deploy",
    "cdk:diff": "cd infrastructure && cdk diff",
    "cdk:bootstrap": "cd infrastructure && cdk bootstrap",
    "deploy:container": "tools/container/deploy.sh",
    "deploy:aws": "tools/aws/deploy.sh",
    "deploy": "npm run deploy:container && npm run deploy:aws"
  },
