{
  "name": "@milestone/js-common",
  "version": "1.0.0",
  "description": "Common JS/React library for milestone",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./schema/*": {
      "types": "./dist/schema/*.d.ts",
      "import": "./dist/schema/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@milestone/data": "*",
    "countries-list": "^3.1.1",
    "croner": "^9.1.0",
    "date-fns": "^3.6.0",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.6",
    "react": "^18.3.1",
    "rrule": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.11",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  }
}
