{
  "name": "@milestone/js-common",
  "version": "1.0.0",
  "description": "Common JS/React library for milestone",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./schema/*": {
      "types": "./dist/schema/*.d.ts",
      "import": "./dist/schema/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    },
    "./api/*": {
      "types": "./dist/api/*.d.ts",
      "import": "./dist/api/*.js"
    },
    "./platform/*": {
      "types": "./dist/platform/*.d.ts",
      "import": "./dist/platform/*.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/context/*": {
      "types": "./dist/react/context/*.d.ts",
      "import": "./dist/react/context/*.js"
    },
    "./react/hooks/*": {
      "types": "./dist/react/hooks/*.d.ts",
      "import": "./dist/react/hooks/*.js"
    },
    "./react/chart/*": {
      "types": "./dist/react/chart/*.d.ts",
      "import": "./dist/react/chart/*.js"
    },
    "./react/form/*": {
      "types": "./dist/react/form/*.d.ts",
      "import": "./dist/react/form/*.js"
    },
    "./react/types/*": {
      "types": "./dist/react/types/*.d.ts",
      "import": "./dist/react/types/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@milestone/data": "*",
    "@hookform/resolvers": "^3.9.1",
    "countries-list": "^3.1.1",
    "croner": "^9.1.0",
    "date-fns": "^3.6.0",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.6",
    "rrule": "^2.8.1",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.60.5",
    "d3": "^7.9.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.62.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/react-query": "^5.60.5",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.0",
    "d3": "^7.9.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.62.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.8"
  }
}
